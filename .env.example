# Copy this file to .env and fill in your values
# Never commit .env to git

FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# Cloudinary (https://cloudinary.com — free account)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# PayFast (https://www.payfast.co.za)
# Sandbox credentials for testing (already filled in)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# Your app's public URL (used for PayFast return URLs)
# In development: http://localhost:5000
# In production: https://your-railway-domain.up.railway.app
APP_URL=http://localhost:5000

# Database — leave blank for SQLite in development
# Railway will set this automatically for production
DATABASE_URL=

# Admin panel password — change this before going live!
ADMIN_PASSWORD=change-me

# Email (SMTP) — used for order confirmations and shipping alerts
# For Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=hello@memorylaneprints.co.za
MAIL_PASSWORD=your-gmail-app-password

# Sentry error monitoring (https://sentry.io — free tier)
# Leave blank to disable
SENTRY_DSN=
